# Base de dados PostgreSQL
# Formato: postgresql://UTILIZADOR:PASSWORD@HOST:PORT/NOME_BD
DATABASE_URL="postgresql://postgres:password@localhost:5432/order_management"

# JWT - usa uma string longa e aleatória (mínimo 32 caracteres)
JWT_SECRET="substitui_isto_por_uma_chave_secreta_muito_longa_e_aleatoria"
JWT_REFRESH_SECRET="outra_chave_secreta_diferente_para_refresh_tokens"

# Expiração dos tokens
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# Porta do servidor
PORT=3000

# Ambiente
NODE_ENV="development"
