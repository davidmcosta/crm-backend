// ============================================================
// PASSO: substituir o conteúdo de prisma/schema.prisma por isto
// Depois correr: npx prisma migrate dev --name redesign_ordens
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  OPERATOR
  VIEWER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PRODUCTION
  READY
  DELIVERED
  CANCELLED
}

model User {
  id            String               @id @default(uuid())
  email         String               @unique
  password      String
  name          String
  role          UserRole             @default(OPERATOR)
  isActive      Boolean              @default(true)
  orders        Order[]              @relation("OrdersCreatedBy")
  statusChanges OrderStatusHistory[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  email     String?  @unique
  phone     String?
  address   String?
  notes     String?
  isActive  Boolean  @default(true)
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id          String      @id @default(uuid())
  orderNumber String      @unique
  status      OrderStatus @default(PENDING)

  // Trabalho
  trabalho String @db.Text

  // Cemitério
  cemiterio       String?
  talhao          String?
  numeroSepultura String?

  // Falecido
  fotoPessoa    String? @db.Text // base64 data URL
  nomeFalecido  String? // opcional — por vezes só existe foto
  datasFalecido String? // ex: "01/01/1950 - 15/03/2026"

  // Produtos (lista dinâmica de artigos)
  produtos Json @default("[]")

  // Valores
  valorSepultura     Decimal @default(0) @db.Decimal(10, 2)
  km                 Float?
  portagens          Decimal @default(0) @db.Decimal(10, 2)
  refeicoes          Decimal @default(0) @db.Decimal(10, 2) // refeições colaboradores
  deslocacaoMontagem Decimal @default(0) @db.Decimal(10, 2)
  extrasDescricao    String?
  extrasValor        Decimal @default(0) @db.Decimal(10, 2)
  valorTotal         Decimal @default(0) @db.Decimal(10, 2)

  // Requerente
  requerente  String
  contacto    String
  observacoes String?

  // Relações
  customerId    String?
  customer      Customer?            @relation(fields: [customerId], references: [id])
  createdById   String
  createdBy     User                 @relation("OrdersCreatedBy", fields: [createdById], references: [id])
  statusHistory OrderStatusHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderStatusHistory {
  id          String      @id @default(uuid())
  orderId     String
  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status      OrderStatus
  notes       String?
  changedById String
  changedBy   User        @relation(fields: [changedById], references: [id])
  createdAt   DateTime    @default(now())
}
